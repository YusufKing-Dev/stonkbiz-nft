# Pinata API JWT for IPFS uploads (get from https://app.pinata.cloud/developers/api-keys)
PINATA_JWT=your_pinata_jwt_here

# Private key of the deployer wallet (WITHOUT 0x prefix)
PRIVATE_KEY=your_wallet_private_key_here

# BaseScan API key for contract verification (get from https://basescan.org)
BASESCAN_API_KEY=your_basescan_api_key_here
